import numpy as np
import matplotlib.pyplot as plt
import matplotlib

matplotlib.rcParams.update({
    'font.family': 'serif',
    'font.size': 11,
    'axes.labelsize': 13,
    'axes.titlesize': 14,
    'legend.fontsize': 11,
    'figure.dpi': 200,
})

# Les CSV-filen
rows = []
with open('C:/Users/emilg/Downloads/Spektrum1&2.csv', 'r', encoding='latin-1') as f:
    for line in f:
        if line.startswith('#') or line.strip() == '':
            continue
        if line.startswith('Frequency'):
            continue
        parts = line.strip().split(',')
        rows.append([float(x) for x in parts])

data = np.array(rows)

freq = data[:, 0]        # Frekvens [Hz]
trace1 = data[:, 1]      # Inngang C1 [dB]
trace2 = data[:, 3]      # Utgang C2 [dB]

fig, ax = plt.subplots(figsize=(8, 5))

ax.plot(freq, trace1, linewidth=0.7, color="#f2790fff", label='Inngang (Scope 1)', alpha=0.85)
ax.plot(freq, trace2, linewidth=0.7, color="#0C2AD4", label='Utgang (Scope 2)', alpha=0.85)

# Marker pipetonen — finn toppen i Trace 1 rundt 1137 Hz
mask = (freq > 1100) & (freq < 1170)
idx_peak = np.argmax(trace1[mask])
f_pipe = freq[mask][idx_peak]
amp_pipe = trace1[mask][idx_peak]

ax.axvline(f_pipe, color='red', linestyle='--', linewidth=1, alpha=0.5)
ax.annotate(f'$f_0 = {f_pipe:.1f}$ Hz',
            xy=(f_pipe, amp_pipe), xytext=(f_pipe + 500, amp_pipe - 15),
            fontsize=10, color='red',
            arrowprops=dict(arrowstyle='->', color='red', lw=1.2))

ax.set_xlabel('Frekvens $f$ [Hz]')
ax.set_ylabel('Amplitude [dB]')
ax.set_title('Spektrumanalyse — inngang og utgang')
ax.set_xlim(0, 5000)
ax.legend(loc='upper right')
ax.grid(True, alpha=0.3)

plt.tight_layout()

